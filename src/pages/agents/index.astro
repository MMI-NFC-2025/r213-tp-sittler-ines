---
import Layout from "../../layouts/Layout.astro";
import { getAgents } from "../../js/backend.mjs";

const agents = await getAgents();
---

<Layout titre="Agents">
  <section class="page-shell">
    <div class="page-head">
      <div>
        <p class="page-kicker">Equipe immo</p>
        <h1>Nos agents</h1>
        <p class="page-note">Choisis un agent pour voir ses offres liees.</p>
      </div>
      <p class="m-0 text-slate-600 font-semibold">{agents.length} agent(s)</p>
    </div>

    {agents.length === 0 ? (
      <p class="panel-card p-5 text-slate-600 reveal">Aucun agent trouve.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {agents.map((agent, index) => {
          const nom = agent.nom ?? agent.Nom ?? "";
          const prenom = agent.prenom ?? agent.Prenom ?? "";
          const email = agent.email ?? agent.Email ?? "";
          const telephone = agent.telephone ?? agent.Telephone ?? "";
          const displayName = `${prenom} ${nom}`.trim() || `Agent ${agent.id}`;

          return (
            <article class="panel-card p-5 reveal" style={`animation-delay:${index * 0.05}s`}>
              <p class="m-0 text-xs uppercase tracking-wider text-slate-500">Conseiller</p>
              <h2 class="mt-1 mb-3 text-xl font-semibold text-slate-900">{displayName}</h2>
              {email && <p class="m-0 text-slate-700 text-sm">{email}</p>}
              {telephone && <p class="mt-1 mb-0 text-slate-600 text-sm">{telephone}</p>}
              <a href={`/agents/${agent.id}`} class="solid-btn inline-block mt-4">Voir ses offres</a>
            </article>
          );
        })}
      </div>
    )}
  </section>
</Layout>
