---
import Layout from "../../layouts/Layout.astro";
import { getAgents } from "../../js/backend.mjs";

const agents = await getAgents();
---

<Layout titre="Agents">
  <h1 class="text-3xl font-bold text-blue-800 mb-6">Nos agents</h1>

  {agents.length === 0 ? (
    <p>Aucun agent trouve.</p>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {agents.map((agent) => {
        const nom = agent.nom ?? agent.Nom ?? "";
        const prenom = agent.prenom ?? agent.Prenom ?? "";
        const email = agent.email ?? agent.Email ?? "";
        const displayName = `${prenom} ${nom}`.trim() || `Agent ${agent.id}`;

        return (
          <article class="bg-blue-50 border border-blue-200 rounded-2xl p-5 shadow-sm">
            <h2 class="text-xl font-semibold text-blue-900">{displayName}</h2>
            {email && <p class="text-blue-700 mt-2">{email}</p>}
            <a href={`/agents/${agent.id}`} class="mt-3 inline-block text-blue-700 hover:underline">
              Voir ses offres
            </a>
          </article>
        );
      })}
    </div>
  )}
</Layout>
