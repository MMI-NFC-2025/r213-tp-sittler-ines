---
import Layout from "../../layouts/Layout.astro";
import OffreCard from "../../components/OffreCard.astro";
import { getAgent, getOffresByAgent } from "../../js/backend.mjs";

const { id } = Astro.params;
const agent = await getAgent(id);

if (!agent) {
  return Astro.redirect("/agents");
}

const nom = agent.nom ?? agent.Nom ?? "";
const prenom = agent.prenom ?? agent.Prenom ?? "";
const email = agent.email ?? agent.Email ?? "";
const telephone = agent.telephone ?? agent.Telephone ?? "";
const displayName = `${prenom} ${nom}`.trim() || `Agent ${agent.id}`;
const offres = await getOffresByAgent(id);
---

<Layout titre={`Offres de ${displayName}`}>
  <section class="page-shell">
    <div class="page-head">
      <div>
        <p class="page-kicker">Agent</p>
        <h1>{displayName}</h1>
        <p class="page-note">
          {email}
          {telephone && ` - ${telephone}`}
        </p>
      </div>
      <a href="/agents" class="soft-btn">Retour aux agents</a>
    </div>

    {offres.length === 0 ? (
      <p class="panel-card p-5 text-slate-600 reveal">Aucune offre pour cet agent.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {offres.map((offre) => (
          <OffreCard offre={offre} />
        ))}
      </div>
    )}
  </section>
</Layout>
