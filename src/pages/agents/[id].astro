---
import Layout from "../../layouts/Layout.astro";
import OffreCard from "../../components/OffreCard.astro";
import { getAgent, getOffresByAgent } from "../../js/backend.mjs";

const { id } = Astro.params;
const agent = await getAgent(id);

if (!agent) {
  return Astro.redirect("/agents");
}

const nom = agent.nom ?? agent.Nom ?? "";
const prenom = agent.prenom ?? agent.Prenom ?? "";
const email = agent.email ?? agent.Email ?? "";
const displayName = `${prenom} ${nom}`.trim() || `Agent ${agent.id}`;
const offres = await getOffresByAgent(id);
---

<Layout titre={`Offres de ${displayName}`}>
  <h1 class="text-3xl font-bold text-blue-800 mb-2">Offres de {displayName}</h1>
  {email && <p class="text-blue-700 mb-6">{email}</p>}

  {offres.length === 0 ? (
    <p>Aucune offre pour cet agent.</p>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {offres.map((offre) => (
        <OffreCard offre={offre} />
      ))}
    </div>
  )}
</Layout>
