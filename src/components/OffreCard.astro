---
import PbImage from './PbImage.astro';

interface Props {
  offre: any;
}

const { offre } = Astro.props;
const nomMaison = offre.nomMaison ?? offre.Nom;
const favori = offre.favori ?? offre.Favori;
const image =
  offre.images?.[0] ??
  (Array.isArray(offre.Image) ? offre.Image[0] : offre.Image);
---

<article
  class="offre bg-blue-50 border border-blue-200 rounded-2xl shadow-sm overflow-hidden hover:shadow-md transition"
  data-favori={favori ? 'true' : 'false'}
>
  <!-- Image -->
  <div class="relative h-52 bg-gray-200">
    {image ? (
      <PbImage record={offre} recordImage={image} width={400} height={208} />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-gray-500">
        Pas d'image
      </div>
    )}

    <button
      type="button"
      class="favoriteButton absolute bottom-0 left-0 p-2 text-white rounded-tr-lg bg-blue-900/80 hover:bg-blue-900"
      data-offre={JSON.stringify(offre)}
      aria-label="Ajouter aux favoris"
    >
      <span class="favorite-icon text-2xl leading-none" aria-hidden="true">
        {favori ? "\u2605" : "\u2606"}
      </span>
    </button>

    {favori && (
      <span class="absolute top-3 right-3 bg-blue-800 text-blue-100 text-xs px-3 py-1 rounded-full">
        {"\u2605 Favori"}
      </span>
    )}
  </div>

  <!-- Contenu -->
  <div class="p-5 text-blue-900">
    <h2 class="font-semibold text-lg text-blue-800">
      {nomMaison}
    </h2>
    <a href={`/offres/${offre.id}`} class="mt-2 inline-block text-sm text-blue-700 hover:underline">
      Voir plus
    </a>
  </div>
</article>

<script>
  //@ts-nocheck
  import { setFavori } from "../js/backend.mjs";
  const favoriteButtons = document.querySelectorAll(".favoriteButton");

  favoriteButtons.forEach((button) => {
    button.addEventListener('click', async () => {
      const offreData = JSON.parse(button.dataset.offre || '{}');
      const currentFavori = offreData.favori ?? offreData.Favori ?? false;
      offreData.favori = currentFavori;
      const newFavori = !currentFavori;

      try {
        await setFavori(offreData);
      } catch (error) {
        console.error("Impossible de mettre a jour le favori", error);
        return;
      }

      const favIcon = button.querySelector('.favorite-icon');
      if (favIcon) {
        favIcon.textContent = newFavori ? "\u2605" : "\u2606";
      }

      offreData.favori = newFavori;
      offreData.Favori = newFavori;
      button.dataset.offre = JSON.stringify(offreData);

      const card = button.closest('.offre');
      if (card) {
        card.setAttribute('data-favori', newFavori ? 'true' : 'false');
      }
    });
  });
</script>
