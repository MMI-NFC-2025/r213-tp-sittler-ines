---
import { getImageUrl } from '../js/backend.mjs';

const { 
  record, 
  recordImage,
  width = 400,
  height = 300,
} = Astro.props;

const imageURL = await getImageUrl(record, recordImage);
---

{imageURL && 
    <img
        src={imageURL}
        alt={record.nomMaison || record.Nom || 'Image'}
        width={width}
        height={height}
        style="width: 100%; height: 100%; object-fit: cover;"
    />
}
